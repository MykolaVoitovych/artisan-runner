{
    "name": "mykolavoitovych/artisan-runner",
    "description": "Run Artisan commands via the web with Nova authentication and real-time output",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "laravel/framework": "^12.0|^13.0",
        "laravel/nova": "^5.0",
        "symfony/process": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "Mykolavoitovych\\ArtisanRunner\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mykolavoitovych\\ArtisanRunner\\ArtisanRunnerServiceProvider"
            ]
        }
    }
}
